<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <OutputType>Exe</OutputType>
        <PackAsTool>true</PackAsTool>
        <ToolCommandName>fs-hot-watch</ToolCommandName>
        <PackageId>FsHotWatch.Cli</PackageId>
        <Version>0.1.0-alpha.1</Version>
        <Authors>Michael Glass</Authors>
        <Description>CLI for FsHotWatch — F# file watcher daemon</Description>
        <PackageLicenseExpression>MIT</PackageLicenseExpression>
        <NoWarn>$(NoWarn);NU1605;MSB3277;NETSDK1188</NoWarn>
    </PropertyGroup>

    <ItemGroup>
        <Compile Include="Program.fs" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="../FsHotWatch/FsHotWatch.fsproj" />
    </ItemGroup>
</Project>
