{
  "build": {
    "command": "dotnet",
    "args": "build"
  },
  "format": true,
  "lint": false,
  "analyzers": {
    "paths": ["tools/fsharplint-shim/bin/Release/net10.0/"]
  },
  "tests": {
    "beforeRun": "dotnet build",
    "projects": [
      {
        "project": "FsHotWatch.Tests",
        "command": "dotnet",
        "args": "run --project tests/FsHotWatch.Tests --no-build --",
        "filterTemplate": "--filter-class {classes}",
        "classJoin": " ",
        "group": "default"
      }
    ]
  },
  "coverage": {
    "directory": "./coverage"
  }
}
