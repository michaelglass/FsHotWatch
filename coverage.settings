<?xml version="1.0" encoding="utf-8"?>
<Configuration>
  <CodeCoverage>
    <ModulePaths>
      <Exclude>
        <ModulePath>.*Tests\.dll$</ModulePath>
        <ModulePath>.*ExampleAnalyzer\.dll$</ModulePath>
        <ModulePath>.*xunit.*</ModulePath>
        <ModulePath>.*Unquote.*</ModulePath>
      </Exclude>
    </ModulePaths>
  </CodeCoverage>
</Configuration>
